<!--
  2D Reacher - A Simple Robotic Arm
  
  Two-link planar arm that must reach a target position.
  This is a classic robotics RL benchmark.
  
  Key MJCF concepts demonstrated:
  - Multi-joint robot arm
  - Target site (not a physical body - just a visual/reference point)
  - Contact physics (fingertip touching target)
  - Sites: named points in space for reference
-->
<mujoco model="reacher_2d">
  <compiler angle="radian" coordinate="local"/>
  
  <option gravity="0 0 -9.81" timestep="0.002" integrator="RK4"/>
  
  <default>
    <joint damping="0.1" limited="true"/>
    <geom contype="1" conaffinity="1" friction="1 0.005 0.001"/>
  </default>
  
  <visual>
    <headlight ambient="0.4 0.4 0.4"/>
  </visual>
  
  <worldbody>
    <light pos="0 -1 2" dir="0 0.3 -1"/>
    
    <!-- Table surface -->
    <geom type="plane" size="1 1 0.01" rgba="0.85 0.85 0.85 1" pos="0 0 -0.01"/>
    
    <!-- Base (fixed) -->
    <geom type="cylinder" size="0.06 0.02" rgba="0.4 0.4 0.4 1" pos="0 0 0"/>
    
    <!-- Target (visual marker - this is a "site", a massless reference point) -->
    <body name="target" pos="0.2 0 0.01">
      <geom name="target_geom" type="sphere" size="0.03" rgba="0.2 0.9 0.2 0.8"
            contype="0" conaffinity="0"/>  <!-- No collision -->
      <!-- Site marks the exact target position -->
      <site name="target_site" size="0.01" rgba="1 0 0 1"/>
    </body>
    
    <!-- Robot arm -->
    <body name="upper_arm" pos="0 0 0.02">
      <joint name="shoulder" type="hinge" axis="0 0 1" range="-3.14 3.14" damping="0.5"/>
      <geom name="upper_arm_geom" type="capsule" size="0.02" fromto="0 0 0 0.15 0 0"
            rgba="0.2 0.4 0.9 1" mass="0.5"/>
      
      <!-- Forearm (child of upper arm) -->
      <body name="forearm" pos="0.15 0 0">
        <joint name="elbow" type="hinge" axis="0 0 1" range="-2.8 2.8" damping="0.3"/>
        <geom name="forearm_geom" type="capsule" size="0.015" fromto="0 0 0 0.12 0 0"
              rgba="0.4 0.6 0.9 1" mass="0.3"/>
        
        <!-- Fingertip site (for measuring distance to target) -->
        <site name="fingertip" pos="0.12 0 0" size="0.015" rgba="0.9 0.2 0.2 1"/>
        <geom name="fingertip_geom" type="sphere" size="0.02" pos="0.12 0 0"
              rgba="0.9 0.3 0.3 1" mass="0.05"/>
      </body>
    </body>
  </worldbody>
  
  <actuator>
    <motor name="shoulder_motor" joint="shoulder" gear="5" ctrllimited="true" ctrlrange="-1 1"/>
    <motor name="elbow_motor" joint="elbow" gear="3" ctrllimited="true" ctrlrange="-1 1"/>
  </actuator>
  
  <sensor>
    <jointpos name="shoulder_pos" joint="shoulder"/>
    <jointvel name="shoulder_vel" joint="shoulder"/>
    <jointpos name="elbow_pos" joint="elbow"/>
    <jointvel name="elbow_vel" joint="elbow"/>
    <!-- Site-based sensors -->
    <framepos name="fingertip_pos" objtype="site" objname="fingertip"/>
    <framepos name="target_pos" objtype="site" objname="target_site"/>
  </sensor>
</mujoco>
