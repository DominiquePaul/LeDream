<!--
  Contact Physics Demo
  
  A scene with objects that collide, stack, and interact through contact.
  Demonstrates MuJoCo's contact solver and friction model.
  
  Key MJCF concepts demonstrated:
  - Free joints (6 DOF - unconstrained rigid body)
  - Contact parameters: friction, solref, solimp
  - Material properties
  - Multiple interacting bodies
  - contype/conaffinity: collision filtering bitmasks
-->
<mujoco model="contact_demo">
  <compiler angle="radian"/>
  
  <option gravity="0 0 -9.81" timestep="0.002">
    <!-- Contact solver parameters -->
    <flag warmstart="enable"/>
  </option>
  
  <default>
    <geom contype="1" conaffinity="1" friction="0.8 0.005 0.001"
          solref="0.02 1" solimp="0.9 0.95 0.001"/>
  </default>
  
  <asset>
    <!-- Materials define visual appearance -->
    <material name="floor_mat" rgba="0.8 0.8 0.8 1" reflectance="0.3"/>
    <material name="box_mat" rgba="0.2 0.5 0.9 1"/>
    <material name="ball_mat" rgba="0.9 0.3 0.2 1"/>
    <material name="wall_mat" rgba="0.5 0.5 0.5 0.3"/>
  </asset>
  
  <visual>
    <headlight ambient="0.3 0.3 0.3"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>
  
  <worldbody>
    <light pos="0 -2 3" dir="0 0.4 -1" diffuse="1 1 1" castshadow="true"/>
    <light pos="2 2 3" dir="-0.3 -0.3 -1" diffuse="0.5 0.5 0.5"/>
    
    <!-- Ground plane -->
    <geom type="plane" size="3 3 0.1" material="floor_mat"/>
    
    <!-- Walls (for containment) -->
    <geom type="box" size="3 0.05 0.3" pos="0 -1 0.3" material="wall_mat"/>
    <geom type="box" size="3 0.05 0.3" pos="0 1 0.3" material="wall_mat"/>
    <geom type="box" size="0.05 1 0.3" pos="-1 0 0.3" material="wall_mat"/>
    <geom type="box" size="0.05 1 0.3" pos="1 0 0.3" material="wall_mat"/>
    
    <!-- Box 1: free-floating body (6 DOF) -->
    <body name="box1" pos="0 0 0.5">
      <!-- Free joint: gives body full 6 DOF (3 translation + 3 rotation) -->
      <freejoint name="box1_free"/>
      <geom type="box" size="0.1 0.1 0.1" material="box_mat" mass="1.0"/>
    </body>
    
    <!-- Box 2: stacked above -->
    <body name="box2" pos="0.05 0.05 0.8">
      <freejoint name="box2_free"/>
      <geom type="box" size="0.08 0.08 0.08" rgba="0.3 0.8 0.3 1" mass="0.5"/>
    </body>
    
    <!-- Ball -->
    <body name="ball" pos="0.4 0 1.0">
      <freejoint name="ball_free"/>
      <geom type="sphere" size="0.08" material="ball_mat" mass="0.3"/>
    </body>
    
    <!-- Capsule (cylinder with rounded ends) -->
    <body name="capsule" pos="-0.3 0.2 0.6">
      <freejoint name="capsule_free"/>
      <geom type="capsule" size="0.04" fromto="-0.1 0 0 0.1 0 0"
            rgba="0.8 0.6 0.1 1" mass="0.4"/>
    </body>
    
    <!-- A ramp to show rolling/sliding -->
    <geom type="box" size="0.4 0.3 0.01" pos="-0.3 -0.3 0.15"
          euler="0 0.3 0" rgba="0.6 0.4 0.2 1"/>
  </worldbody>
</mujoco>
